generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  email            String        @unique
  emailVerified    Boolean       @default(false)
  name             String?
  image            String?
  collage          String?
  collageId        String?
  branch           String?
  year             Int?
  isApproved       Boolean       @default(false)
  paymentStatus    PaymentStatus @default(PENDING)
  ticketScanned    Boolean       @default(false)
  ticketScannedAt  DateTime?
  phone            String?
  gender           String?
  password         String?
  judgePassword    String?
  state            String?
  city             String?
  isInternational  Boolean       @default(false)
  country          String?
  role             Role          @default(USER)
  accounts              Account[]
  sessions              Session[]
  assignedEventId    String?
  assignedEvent      Event?        @relation("EventJudges", fields: [assignedEventId], references: [id])
  passes                Pass[]
  accommodationBookings AccommodationBooking[]
  eventSubmissions      EventSubmission[]
  individualRegistrations IndividualRegistration[]
  groupRegistrations    GroupRegistration[]
  visitorPassRegistrations VisitorPassRegistration[]
  evaluationsGiven      Evaluation[]             @relation("JudgeEvaluations")
  evaluationsReceived   Evaluation[]             @relation("ParticipantEvaluations")

  @@index([paymentStatus])
  @@index([role])
  @@index([isApproved])
  @@index([collage])
  @@map("users")
}

model Pass {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  passToken   String?   @unique
  eventId     String?
  passType    String   @default("GENERAL")
  
  // Payment fields for visitor pass
  paymentScreenshot String?
  utrId             String?
  payeeName         String?
  paymentStatus     PaymentStatus @default(PENDING)
  
  isActive    Boolean  @default(true)
  isUsed      Boolean  @default(false)
  usedAt      DateTime?
  usedBy      String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?
  
  @@index([passToken])
  @@index([userId])
  @@map("passes")
}

model Session {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  identifier String
  value      String
  expiresAt  DateTime

  @@map("verifications")
}

model Category {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime
  name      String
  image     String?
  video     String?
  slug      String   @unique @default(cuid())
  Event     Event[]
}

model Event {
  id                 String   @id
  categoryId         String
  name               String
  description        String
  date               DateTime
  image              String
  slug               String   @unique @default(cuid())

  venue              String
  startTime          String
  endTime            String
  participantLimit   Int
  isGroupEvent       Boolean  @default(false)
  isResultPublished  Boolean  @default(false)
  allowSubmissions   Boolean  @default(false)
  minTeamSize        Int      @default(1)
  maxTeamSize        Int      @default(1)
  termsandconditions String
  registrationLink   String
  whatsappLink       String?
  brochureLink       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  Category           Category @relation(fields: [categoryId], references: [id])
  submissions        EventSubmission[]
  individualRegistrations IndividualRegistration[]
  groupRegistrations GroupRegistration[]
  evaluations        Evaluation[]
  judges             User[]   @relation("EventJudges")
}

model GroupRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  groupName String?
  mentorName String?
  mentorPhone String?
  members   Json
  registrationDetails Json?

  // Payment Verification
  paymentScreenshot String?
  utrId            String?
  payeeName        String?
  paymentStatus    PaymentStatus @default(PENDING)

  // Approval tracking
  approvedBy       String?  // User ID of who approved/rejected
  approvedAt       DateTime?

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@index([paymentStatus])
  @@index([approvedBy])
  @@map("group_registrations")
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
  JUDGE
  MANAGER
  MASTER
}

enum Gender {
  MALE
  FEMALE
}

enum BookingType {
  INDIVIDUAL
  GROUP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

model AccommodationBooking {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // User reference
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Booking details
  gender       Gender
  bookingType  BookingType

  // Primary contact (stored for record keeping)
  primaryName  String
  primaryEmail String
  primaryPhone String

  // Group members (stored as JSON array)
  groupMembers Json?

  // Total members count
  totalMembers Int

  // Payment
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?
  amount        Decimal?      @db.Decimal(10, 2)

  // Booking status
  status       BookingStatus @default(PENDING)

  // Ensure one booking per user
  @@unique([userId])
  @@index([paymentStatus])
  @@index([status])
  @@map("accommodation_bookings")
}

model EventSubmission {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  eventId        String

  submissionLink String
  notes          String?
  registrationDetails Json?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_submissions")
}

model IndividualRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  registrationDetails Json? // For any future extra fields

  // Payment Verification
  paymentScreenshot String?
  utrId            String?
  payeeName        String?
  paymentStatus    PaymentStatus @default(PENDING)

  // Approval tracking
  approvedBy       String?  // User ID of who approved/rejected
  approvedAt       DateTime?

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@index([paymentStatus])
  @@index([approvedBy])
  @@map("individual_registrations")
}

model VisitorPassRegistration {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  passToken          String?  @unique
  paymentScreenshot  String?
  utrId              String?
  payeeName          String?
  paymentStatus      PaymentStatus @default(PENDING)

  // Approval tracking
  approvedBy         String?  // User ID of who approved/rejected
  approvedAt         DateTime?

  isUsed             Boolean  @default(false)
  usedAt             DateTime?
  usedBy             String?

  @@index([userId])
  @@index([paymentStatus])
  @@index([passToken])
  @@index([approvedBy])
  @@map("visitor_pass_registrations")
}



model ChatbotCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  image     String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chatbot_categories")
}

model ChatbotFAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chatbot_faqs")
}

model Evaluation {
  id            String   @id @default(cuid())
  score         Float
  remarks       String?
  
  judgeId       String
  judge         User     @relation("JudgeEvaluations", fields: [judgeId], references: [id], onDelete: Cascade)
  
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  participantId String
  participant   User     @relation("ParticipantEvaluations", fields: [participantId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([judgeId, eventId, participantId])
  @@index([eventId])
  @@index([judgeId])
  @@index([participantId])
  @@map("evaluations")
}

model Sponsor {
  id          String   @id @default(cuid())
  name        String   // Company/Sponsor name
  description String   // Short description
  sponsoredFor String  @default("") // What the sponsor is sponsoring for
  image       String?  // Image URL (Cloudflare R2)
  website     String?  // Optional website URL
  borderColor String   @default("#dc2626") // Card border color
  gradient    String   @default("linear-gradient(145deg,#dc2626,#000)") // Card gradient
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sponsors")
}

model Schedule {
  id        String   @id @default(cuid())
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedules")
}

model ContactCategory {
  id           String               @id @default(cuid())
  name         String
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  coordinators ContactCoordinator[]

  @@map("contact_categories")
}

model ContactCoordinator {
  id         String          @id @default(cuid())
  name       String
  phone      String
  email      String
  image      String?
  order      Int             @default(0)
  categoryId String
  category   ContactCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@map("contact_coordinators")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String   // R2 Public URL
  year      String   // e.g. "2025"
  title     String?  // Optional title
  width     Int?     // For Masonry layout optimization
  height    Int?     // For Masonry layout optimization
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_images")
}

model AdminActivityLog {
  id         String   @id @default(cuid())
  userId     String
  userEmail  String
  userName   String?
  userRole   String
  action     String   // ADD_EVENT, EDIT_EVENT, UPLOAD_CATEGORY_IMAGE, etc.
  entityType String   // CATEGORY, EVENT, etc.
  entityId   String?
  entityName String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_activity_logs")
}

model DeleteRequest {
  id              String   @id @default(cuid())
  requestedById   String
  requestedByEmail String
  requestedByName String?
  requestedByRole String
  entityType      String   // CATEGORY | EVENT
  entityId        String
  entityName      String?
  categoryId      String?  // For EVENT, parent category
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  decidedById     String?
  decidedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([requestedById])
  @@map("delete_requests")
}
