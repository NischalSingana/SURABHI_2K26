generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                    @id
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @default(now()) @updatedAt
  email                    String                    @unique
  emailVerified            Boolean                   @default(false)
  name                     String?
  banned                   Boolean                   @default(false)
  image                    String?
  collage                  String?
  collageId                String?
  branch                   String?
  year                     Int?
  isApproved               Boolean                   @default(false)
  paymentStatus            PaymentStatus             @default(PENDING)
  phone                    String?
  password                 String?
  role                     Role                      @default(USER)
  ticketScanned            Boolean                   @default(false)
  ticketScannedAt          DateTime?
  gender                   String?
  city                     String?
  state                    String?
  judgePassword            String?
  assignedEventId          String?
  country                  String?
  isInternational          Boolean                   @default(false)
  certificateId            String?
  accommodationBookings    AccommodationBooking[]
  accounts                 Account[]
  evaluationsGiven         Evaluation[]              @relation("JudgeEvaluations")
  evaluationsReceived      Evaluation[]              @relation("ParticipantEvaluations")
  eventSubmissions         EventSubmission[]
  groupRegistrations       GroupRegistration[]
  individualRegistrations  IndividualRegistration[]
  passes                   Pass[]
  sessions                 Session[]
  assignedEvent            Event?                    @relation("EventJudges", fields: [assignedEventId], references: [id])
  visitorPassRegistrations VisitorPassRegistration[]
  competitionFeedbacks     CompetitionFeedback[]

  @@index([paymentStatus])
  @@index([role])
  @@index([isApproved])
  @@index([collage])
  @@map("users")
}

model Pass {
  id                String        @id @default(cuid())
  userId            String
  passToken         String?       @unique
  eventId           String?
  passType          String        @default("GENERAL")
  isActive          Boolean       @default(true)
  isUsed            Boolean       @default(false)
  usedAt            DateTime?
  usedBy            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  expiresAt         DateTime?
  payeeName         String?
  paymentScreenshot String?
  paymentStatus     PaymentStatus @default(PENDING)
  utrId             String?
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([passToken])
  @@index([userId])
  @@map("passes")
}

model Session {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  identifier String
  value      String
  expiresAt  DateTime

  @@map("verifications")
}

model Category {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime
  name      String
  image     String?
  video     String?
  slug      String   @unique @default(cuid())
  Event     Event[]
}

model Event {
  id                        String                   @id
  categoryId                String
  name                      String
  description               String
  date                      DateTime
  image                     String
  venue                     String
  startTime                 String
  endTime                   String
  participantLimit          Int
  termsandconditions        String
  registrationLink          String
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime
  isGroupEvent              Boolean                  @default(false)
  maxTeamSize               Int                      @default(1)
  minTeamSize               Int                      @default(1)
  slug                      String                   @unique @default(cuid())
  whatsappLink              String?
  brochureLink              String?
  isResultPublished         Boolean                  @default(false)
  allowSubmissions          Boolean                  @default(false)
  virtualEnabled            Boolean                  @default(false)
  virtualTermsAndConditions String?
  meetingLink               String?
  meetingTime               String?
  meetingTimezone           String?
  meetingDate               DateTime?
  Category                  Category                 @relation(fields: [categoryId], references: [id])
  evaluations               Evaluation[]
  submissions               EventSubmission[]
  groupRegistrations        GroupRegistration[]
  individualRegistrations   IndividualRegistration[]
  judges                    User[]                   @relation("EventJudges")
  feedbackReleases          FeedbackRelease[]
  competitionFeedbacks      CompetitionFeedback[]

  @@index([categoryId])
  @@index([date])
  @@index([isResultPublished])
  @@index([allowSubmissions])
  @@index([virtualEnabled])
}

model GroupRegistration {
  id                  String        @id @default(cuid())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  eventId             String
  userId              String
  groupName           String?
  members             Json
  mentorName          String?
  mentorPhone         String?
  registrationDetails Json?
  payeeName           String?
  paymentScreenshot   String?
  paymentStatus       PaymentStatus @default(PENDING)
  utrId               String?
  approvedAt          DateTime?
  approvedBy          String?
  isVirtual           Boolean       @default(false)
  event               Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@index([isVirtual])
  @@index([paymentStatus])
  @@index([paymentStatus, updatedAt])
  @@index([userId, paymentStatus, isVirtual])
  @@index([eventId, paymentStatus])
  @@index([approvedBy])
  @@map("group_registrations")
}

model AccommodationBooking {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userId        String
  gender        Gender
  bookingType   BookingType
  primaryName   String
  primaryEmail  String
  primaryPhone  String
  groupMembers  Json?
  totalMembers  Int
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?
  amount        Decimal?      @db.Decimal(10, 2)
  status        BookingStatus @default(PENDING)
  passToken     String?       @unique
  isUsed        Boolean       @default(false)
  usedAt        DateTime?
  usedBy        String?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gender])
  @@index([paymentStatus])
  @@index([status])
  @@index([status, createdAt])
  @@index([userId, status])
  @@index([passToken])
  @@map("accommodation_bookings")
}

model EventSubmission {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  userId              String
  eventId             String
  submissionLink      String
  youtubeChannelName  String?
  notes               String?
  registrationDetails Json?
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_submissions")
}

model IndividualRegistration {
  id                  String        @id @default(cuid())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  eventId             String
  userId              String
  registrationDetails Json?
  payeeName           String?
  paymentScreenshot   String?
  paymentStatus       PaymentStatus @default(PENDING)
  utrId               String?
  approvedAt          DateTime?
  approvedBy          String?
  isVirtual           Boolean       @default(false)
  event               Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@index([isVirtual])
  @@index([paymentStatus])
  @@index([paymentStatus, updatedAt])
  @@index([userId, paymentStatus, isVirtual])
  @@index([eventId, paymentStatus])
  @@index([approvedBy])
  @@map("individual_registrations")
}

model VisitorPassRegistration {
  id                String        @id @default(cuid())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  userId            String
  passToken         String?       @unique
  paymentScreenshot String?
  utrId             String?
  payeeName         String?
  paymentStatus     PaymentStatus @default(PENDING)
  isUsed            Boolean       @default(false)
  usedAt            DateTime?
  usedBy            String?
  approvedAt        DateTime?
  approvedBy        String?
  isManual          Boolean       @default(false)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paymentStatus])
  @@index([passToken])
  @@index([approvedBy])
  @@map("visitor_pass_registrations")
}

model ChatbotCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image     String?

  @@map("chatbot_categories")
}

model ChatbotFAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chatbot_faqs")
}

model Evaluation {
  id            String   @id @default(cuid())
  score         Float
  remarks       String?
  round         Int      @default(1)
  judgeId       String
  eventId       String
  participantId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  judge         User     @relation("JudgeEvaluations", fields: [judgeId], references: [id], onDelete: Cascade)
  participant   User     @relation("ParticipantEvaluations", fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([judgeId, eventId, participantId, round])
  @@index([eventId])
  @@index([judgeId])
  @@index([participantId])
  @@map("evaluations")
}

model Sponsor {
  id           String   @id @default(cuid())
  name         String
  description  String
  image        String?
  website      String?
  borderColor  String   @default("#dc2626")
  gradient     String   @default("linear-gradient(145deg,#dc2626,#000)")
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sponsoredFor String   @default("")

  @@map("sponsors")
}

model Schedule {
  id        String   @id @default(cuid())
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedules")
}

model ContactCategory {
  id           String               @id @default(cuid())
  name         String
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  coordinators ContactCoordinator[]

  @@map("contact_categories")
}

model ContactCoordinator {
  id         String          @id @default(cuid())
  name       String
  phone      String
  email      String
  image      String?
  order      Int             @default(0)
  categoryId String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   ContactCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("contact_coordinators")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  year      String
  title     String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_images")
}

model AdminActivityLog {
  id         String   @id @default(cuid())
  userId     String
  userEmail  String
  userName   String?
  userRole   String
  action     String
  entityType String
  entityId   String?
  entityName String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_activity_logs")
}

model FeedbackRelease {
  id        String   @id @default(cuid())
  eventId   String   @unique
  isReleased Boolean @default(false)
  releasedAt DateTime?
  releasedBy String?
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([isReleased])
  @@map("feedback_releases")
}

model CompetitionFeedback {
  id             String   @id @default(cuid())
  userId         String
  eventId        String
  overallRating  Int
  ratings        Json
  suggestions    String?
  createdAt      DateTime @default(now())
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@map("competition_feedbacks")
}

model DeleteRequest {
  id               String    @id @default(cuid())
  requestedById    String
  requestedByEmail String
  requestedByName  String?
  requestedByRole  String
  entityType       String
  entityId         String
  entityName       String?
  categoryId       String?
  status           String    @default("PENDING")
  decidedById      String?
  decidedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([status])
  @@index([requestedById])
  @@map("delete_requests")
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
  JUDGE
  MANAGER
  MASTER
  RNC
  GOD
}

enum Gender {
  MALE
  FEMALE
}

enum BookingType {
  INDIVIDUAL
  GROUP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}
